# ============================================================
#  yclients-notification-bot — Environment Variables Example
#  Скопируйте этот файл в .env и заполните реальными значениями.
#  НИКОГДА не коммитьте .env в git!
# ============================================================

# ── YClients ─────────────────────────────────────────────────────────────────
# Bearer-токен авторизации YClients API (получить в настройках интеграции)
YCLIENTS_API_TOKEN=your_yclients_api_token_here

# Числовой ID вашей компании в YClients
YCLIENTS_COMPANY_ID=123456

# Секретный ключ для валидации HMAC-SHA256 подписи входящих webhook от YClients
YCLIENTS_WEBHOOK_SECRET=your_webhook_secret_here

# ── Telegram ─────────────────────────────────────────────────────────────────
# Токен Telegram-бота (получить у @BotFather командой /newbot)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── WhatsApp Business Cloud API ───────────────────────────────────────────────
# Bearer-токен Graph API (Meta Business Manager → WhatsApp → API Setup)
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here

# ID номера телефона бизнеса (Phone Number ID в Meta Business Manager)
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# ID бизнес-аккаунта WhatsApp (WhatsApp Business Account ID)
WHATSAPP_BUSINESS_ACCOUNT_ID=9876543210987654

# Токен верификации webhook WhatsApp (произвольная строка, задаётся при настройке webhook)
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token_here

# ── MAX Bot API ───────────────────────────────────────────────────────────────
# Токен бота MAX (получить через MasterBot на platform-api.max.ru)
MAX_BOT_TOKEN=your_max_bot_token_here

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Async PostgreSQL DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://botuser:botpassword@postgres:5432/yclients_bot

# Минимальный размер пула соединений SQLAlchemy (рекомендуется: 5)
DB_POOL_MIN_SIZE=5

# Максимальный размер пула соединений SQLAlchemy (рекомендуется: 20)
DB_POOL_MAX_SIZE=20

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis DSN (используется как брокер Celery и кеш шаблонов)
REDIS_URL=redis://redis:6379/0

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Логин администратора для входа в /admin
ADMIN_USERNAME=admin

# Пароль администратора (используйте надёжный пароль в production)
ADMIN_PASSWORD=change_me_in_production

# Секретный ключ для подписи JWT-токенов AdminPanel (минимум 32 символа)
ADMIN_JWT_SECRET=your_very_long_and_random_jwt_secret_key_here_min_32_chars

# Время жизни JWT-токена AdminPanel в минутах (по умолчанию: 60)
ADMIN_JWT_EXPIRE_MINUTES=60

# ── Scheduler / Polling ───────────────────────────────────────────────────────
# Интервал опроса YClients API в секундах (допустимо: 60–180, рекомендуется: 120)
POLLING_INTERVAL_SECONDS=120

# ── Localisation ─────────────────────────────────────────────────────────────
# Часовой пояс организации (IANA timezone name, например: Europe/Moscow)
TIMEZONE=Europe/Moscow

# ── Logging ───────────────────────────────────────────────────────────────────
# Уровень логирования: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Environment ───────────────────────────────────────────────────────────────
# Окружение запуска: development | staging | production
ENVIRONMENT=production

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Ограничение частоты запросов к /webhook/yclients (формат slowapi)
WEBHOOK_RATE_LIMIT=100/minute
